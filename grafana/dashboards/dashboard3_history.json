{
  "title": "Dashboard 3 — Phân tích lịch sử & phiên giao dịch",
  "uid": "history-analysis",
  "tags": ["binance", "history"],
  "refresh": "5m",
  "time": {"from": "now-30d", "to": "now"},
  "panels": [

    {
      "id": 1,
      "title": "Bản đồ nhiệt hiệu suất — % thay đổi giá theo ngày",
      "type": "table",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT date, symbol, ROUND(((day_close - day_open) / NULLIF(day_open, 0) * 100)::numeric, 2) AS change_pct FROM public_public.mart_daily_performance WHERE date >= CURRENT_DATE - INTERVAL '30 days' ORDER BY date DESC, symbol",
        "format": "table", "refId": "A"
      }],
      "options": {"cellHeight": "sm"},
      "fieldConfig": {
        "overrides": [
          {"matcher": {"id": "byName", "options": "change_pct"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "custom.displayMode", "value": "color-background"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "dark-red", "value": -5}, {"color": "red", "value": -2}, {"color": "yellow", "value": -0.5}, {"color": "green", "value": 0.5}, {"color": "dark-green", "value": 2}]}}]}
        ]
      }
    },

    {
      "id": 2,
      "title": "Khối lượng trung bình theo phiên giao dịch",
      "type": "barchart",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT symbol, trading_session, ROUND(avg_total_qty::numeric, 2) AS avg_volume FROM public_public.mart_spread_by_session ORDER BY symbol, trading_session",
        "format": "table", "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"xField": "symbol", "stacking": "none", "groupWidth": 0.7, "legend": {"displayMode": "list", "placement": "bottom"}}
    },

    {
      "id": 3,
      "title": "Biến động (Volatility) — Amplitude trung bình theo đồng",
      "type": "bargauge",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT symbol, ROUND(AVG(avg_amplitude)::numeric * 100, 4) AS avg_volatility_pct FROM public_public.mart_daily_performance GROUP BY symbol ORDER BY avg_volatility_pct DESC",
        "format": "table", "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 2}, {"color": "red", "value": 5}]}, "color": {"mode": "thresholds"}}},
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}
    },

    {
      "id": 4,
      "title": "Tỷ lệ nến tăng / giảm (30 ngày)",
      "type": "barchart",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT symbol, ROUND(SUM(bullish_candles)::numeric / NULLIF(SUM(candle_count), 0) * 100, 1) AS bullish_pct, ROUND(SUM(bearish_candles)::numeric / NULLIF(SUM(candle_count), 0) * 100, 1) AS bearish_pct FROM public_public.mart_daily_performance WHERE date >= CURRENT_DATE - INTERVAL '30 days' GROUP BY symbol ORDER BY bullish_pct DESC",
        "format": "table", "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {"unit": "percent"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "bullish_pct"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "bearish_pct"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
        ]
      },
      "options": {"xField": "symbol", "stacking": "none", "groupWidth": 0.7, "legend": {"displayMode": "list", "placement": "bottom"}}
    },

    {
      "id": 5,
      "title": "Top biến động mạnh nhất hôm nay",
      "type": "table",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT symbol, day_open, day_high, day_low, day_close, day_volume, ROUND(((day_close - day_open) / NULLIF(day_open, 0) * 100)::numeric, 2) AS change_pct, ROUND((avg_amplitude * 100)::numeric, 4) AS amplitude_pct FROM public_public.mart_daily_performance WHERE date = CURRENT_DATE ORDER BY ABS((day_close - day_open) / NULLIF(day_open, 0)) DESC",
        "format": "table", "refId": "A"
      }],
      "options": {"cellHeight": "sm"},
      "fieldConfig": {
        "overrides": [
          {"matcher": {"id": "byName", "options": "change_pct"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "custom.displayMode", "value": "color-background"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 0}]}}]},
          {"matcher": {"id": "byName", "options": "day_volume"}, "properties": [{"id": "unit", "value": "short"}]},
          {"matcher": {"id": "byName", "options": "day_open"}, "properties": [{"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "day_close"}, "properties": [{"id": "unit", "value": "currencyUSD"}]}
        ]
      }
    },

    {
      "id": 6,
      "title": "Lịch sử cảnh báo (Timeline)",
      "type": "table",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT triggered_at, symbol, alert_code, alert_description, severity, trigger_value, threshold_pct, is_resolved, resolved_at, trading_session FROM public_public.mart_alert_summary ORDER BY triggered_at DESC LIMIT 100",
        "format": "table", "refId": "A"
      }],
      "options": {"cellHeight": "sm", "footer": {"show": true, "reducer": ["count"], "fields": ["alert_key"]}},
      "fieldConfig": {
        "overrides": [
          {"matcher": {"id": "byName", "options": "severity"}, "properties": [{"id": "custom.displayMode", "value": "color-background"}, {"id": "mappings", "value": [{"type": "value", "options": {"HIGH": {"color": "red", "index": 0}, "MEDIUM": {"color": "orange", "index": 1}, "LOW": {"color": "yellow", "index": 2}}}]}]},
          {"matcher": {"id": "byName", "options": "threshold_pct"}, "properties": [{"id": "unit", "value": "short"}, {"id": "decimals", "value": 2}]},
          {"matcher": {"id": "byName", "options": "is_resolved"}, "properties": [{"id": "mappings", "value": [{"type": "value", "options": {"true": {"text": "Resolved ✓", "color": "green", "index": 0}, "false": {"text": "Active ●", "color": "red", "index": 1}}}]}]}
        ]
      }
    }

  ]
}
