{
  "title": "Crypto Prices & Alerts",
  "uid": "crypto-prices",
  "tags": ["binance", "crypto"],
  "refresh": "5s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Latest Prices",
      "type": "table",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT symbol, display_name, category, last_price, vwap, volume, price_change_pct, trade_count, trading_session, updated_at FROM public_public.mart_latest_prices ORDER BY symbol",
        "format": "table",
        "refId": "A"
      }],
      "options": {
        "sortBy": [{"displayName": "symbol", "desc": false}],
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "overrides": [
          {"matcher": {"id": "byName", "options": "last_price"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "price_change_pct"}, "properties": [{"id": "unit", "value": "percentunit"}, {"id": "custom.displayMode", "value": "color-background"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 0}]}}]},
          {"matcher": {"id": "byName", "options": "trade_count"}, "properties": [{"id": "unit", "value": "short"}]}
        ]
      }
    },
    {
      "id": 2,
      "title": "Recent Alerts",
      "type": "table",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT symbol, alert_code, severity, trigger_value, threshold_pct, triggered_at, is_resolved FROM public_public.mart_alert_summary WHERE triggered_at > NOW() - INTERVAL '24 hours' ORDER BY triggered_at DESC LIMIT 50",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "overrides": [
          {"matcher": {"id": "byName", "options": "severity"}, "properties": [{"id": "custom.displayMode", "value": "color-background"}, {"id": "mappings", "value": [{"type": "value", "options": {"HIGH": {"color": "red", "index": 0}, "MEDIUM": {"color": "orange", "index": 1}, "LOW": {"color": "yellow", "index": 2}}}]}]}
        ]
      }
    },
    {
      "id": 3,
      "title": "Trade Count by Symbol (last 1h)",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT symbol, SUM(trade_count) as total_trades FROM public_public.mart_latest_prices GROUP BY symbol ORDER BY total_trades DESC",
        "format": "table",
        "refId": "A"
      }],
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["sum"]}},
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4,
      "title": "Alert Count by Code (24h)",
      "type": "piechart",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT alert_code, COUNT(*) as cnt FROM public_public.mart_alert_summary WHERE triggered_at > NOW() - INTERVAL '24 hours' GROUP BY alert_code ORDER BY cnt DESC",
        "format": "table",
        "refId": "A"
      }],
      "options": {"pieType": "pie", "legend": {"displayMode": "table", "placement": "right"}}
    }
  ]
}
