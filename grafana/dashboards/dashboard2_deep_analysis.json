{
  "title": "Dashboard 2 — Phân tích chuyên sâu",
  "uid": "deep-analysis",
  "tags": ["binance", "technical"],
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [{
      "name": "symbol",
      "label": "Symbol",
      "type": "query",
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "query": "SELECT DISTINCT symbol FROM public_public.mart_latest_prices ORDER BY symbol",
      "current": {"text": "BTCUSDT", "value": "BTCUSDT"},
      "refresh": 1,
      "sort": 1
    }]
  },
  "panels": [

    {
      "id": 1,
      "title": "Biểu đồ nến (Candlestick) — $symbol",
      "type": "candlestick",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 9},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT TO_TIMESTAMP(open_time / 1000) AS time, open, high, low, close, volume FROM public_staging.stg_kline_closed WHERE symbol = '${symbol}' AND TO_TIMESTAMP(open_time/1000) > NOW() - INTERVAL '6 hours' ORDER BY time",
        "format": "table", "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "open"}, "properties": [{"id": "custom.hideFrom", "value": {"tooltip": false, "viz": false, "legend": false}}]},
          {"matcher": {"id": "byName", "options": "volume"}, "properties": [{"id": "unit", "value": "short"}]}
        ]
      },
      "options": {
        "mode": "candles+volume",
        "candleStyle": "candles",
        "colorStrategy": "open-close",
        "upColor": "green",
        "downColor": "red"
      }
    },

    {
      "id": 2,
      "title": "MACD — $symbol",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 9, "w": 12, "h": 7},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT TO_TIMESTAMP(open_time / 1000) AS time, macd AS \"MACD\", macd_signal AS \"Signal\", macd_hist AS \"Histogram\" FROM public_staging.stg_kline_closed WHERE symbol = '${symbol}' AND TO_TIMESTAMP(open_time/1000) > NOW() - INTERVAL '6 hours' ORDER BY time",
        "format": "time_series", "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "MACD"}, "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Signal"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Histogram"}, "properties": [{"id": "custom.drawStyle", "value": "bars"}, {"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
    },

    {
      "id": 3,
      "title": "RSI (14) — $symbol",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 9, "w": 12, "h": 7},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT TO_TIMESTAMP(open_time / 1000) AS time, rsi_14 AS \"RSI\" FROM public_staging.stg_kline_closed WHERE symbol = '${symbol}' AND rsi_14 IS NOT NULL AND TO_TIMESTAMP(open_time/1000) > NOW() - INTERVAL '6 hours' ORDER BY time",
        "format": "time_series", "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0, "max": 100,
          "custom": {"lineWidth": 2},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 70}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {
        "tooltip": {"mode": "single"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {"unit": "short", "min": 0, "max": 100, "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": [{"matcher": {"id": "byName", "options": "RSI"}, "properties": [{"id": "color", "value": {"fixedColor": "purple", "mode": "fixed"}}]}]
      }
    },

    {
      "id": 4,
      "title": "Order Flow — Mua vs Bán ($symbol)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 7},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT TO_TIMESTAMP(window_start / 1000) AS time, buy_volume AS \"Mua\", -sell_volume AS \"Bán\" FROM public_staging.stg_order_flow WHERE symbol = '${symbol}' AND TO_TIMESTAMP(window_start/1000) > NOW() - INTERVAL '3 hours' ORDER BY time",
        "format": "time_series", "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 0, "fillOpacity": 70, "drawStyle": "bars", "stacking": {"mode": "none"}}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Mua"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Bán"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
    },

    {
      "id": 5,
      "title": "Net Flow — Dòng tiền ròng ($symbol)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 7},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [{
        "rawSql": "SELECT TO_TIMESTAMP(window_start / 1000) AS time, net_flow AS \"Net Flow\" FROM public_staging.stg_order_flow WHERE symbol = '${symbol}' AND TO_TIMESTAMP(window_start/1000) > NOW() - INTERVAL '3 hours' ORDER BY time",
        "format": "time_series", "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 20}},
        "overrides": [{"matcher": {"id": "byName", "options": "Net Flow"}, "properties": [{"id": "color", "value": {"mode": "thresholds"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 0}]}}]}]
      },
      "options": {"tooltip": {"mode": "single"}}
    },

    {
      "id": 6,
      "title": "Thanh khoản Spread — $symbol",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 23, "w": 24, "h": 7},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfld7r9p0l4w0d"},
      "targets": [
        {
          "rawSql": "SELECT TO_TIMESTAMP(snapshot_time / 1000) AS time, bid_qty AS \"Bid Qty\", ask_qty AS \"Ask Qty\" FROM public_staging.stg_spread_snapshot WHERE symbol = '${symbol}' AND TO_TIMESTAMP(snapshot_time/1000) > NOW() - INTERVAL '3 hours' ORDER BY time",
          "format": "time_series", "refId": "A"
        },
        {
          "rawSql": "SELECT TO_TIMESTAMP(snapshot_time / 1000) AS time, spread_pct * 100 AS \"Spread %\" FROM public_staging.stg_spread_snapshot WHERE symbol = '${symbol}' AND TO_TIMESTAMP(snapshot_time/1000) > NOW() - INTERVAL '3 hours' ORDER BY time",
          "format": "time_series", "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 1, "fillOpacity": 20}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Bid Qty"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Ask Qty"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Spread %"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "custom.axisPlacement", "value": "right"}, {"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
    }

  ]
}
